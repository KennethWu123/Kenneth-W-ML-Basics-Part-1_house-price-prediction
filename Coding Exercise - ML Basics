    {
      "cell_type": "code",
      "source": [
        "# Numeric feature names come first (we scaled them), then the OHE category names\n",
        "cat_names = model.named_steps['preprocessor'].named_transformers_['cat'].get_feature_names_out(cat_features).tolist()\n",
        "all_feature_names = num_features + cat_names\n",
        "\n",
        "coef = model.named_steps['classifier'].coef_[0]\n",
