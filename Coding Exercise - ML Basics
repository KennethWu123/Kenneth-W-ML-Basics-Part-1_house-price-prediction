      "cell_type": "code",
      "source": [
        "# Example new customer\n",
        "new_customer = pd.DataFrame({\n",
        "    'age': [35],\n",
        "    'monthly_usage_hours': [20],\n",
        "    'purchase_amount': [150],\n",
        "    'customer_service_calls': [5],\n",
        "    'region': ['West']\n",
        "})\n",
        "\n",
        "churn_probability = model.predict_proba(new_customer)[0, 1]  # P(churn=1)\n",
        "threshold = 0.5\n",
        "churn_prediction = int(churn_probability >= threshold)\n",
        "\n",
        "print(f\"Churn Probability for new customer: {churn_probability:.2f}\")\n",
        "print(f\"Churn Prediction at threshold {threshold} (1 = churn, 0 = no churn): {churn_prediction}\")"
